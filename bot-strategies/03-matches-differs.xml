<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="md_stake">stake</variable>
    <variable id="md_init_stake">initial_stake</variable>
    <variable id="md_profit_target">profit_target</variable>
    <variable id="md_loss_count">loss_count</variable>
    <variable id="md_max_loss">max_loss_streak</variable>
    <variable id="md_prediction">prediction</variable>
  </variables>

  <!-- ═══════════════════════════════════════════════
       MKULIMA TRADER — Matches/Differs Bot
       Strategy : Bet DIGITDIFF (digit ≠ 5) on Vol 50 (1s)
       Entry    : Fixed stake, martingale x2.5 on loss
       Exit     : Stop at profit_target or max_loss_streak
       Note     : Prediction = 5 means "differs from 5"
                  Change prediction (0–9) to target any digit
       ═══════════════════════════════════════════════ -->
  <block type="trade_definition" id="md_trade_def" deletable="false" x="0" y="0">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="md_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ50V</field>
        <next>
          <block type="trade_definition_tradetype" id="md_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">matchesdiffers</field>
            <next>
              <block type="trade_definition_contracttype" id="md_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">differs</field>
                <next>
                  <block type="trade_definition_candleinterval" id="md_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="md_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="md_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <block type="variables_set" id="md_init_stake_set">
        <field name="VAR" id="md_init_stake">initial_stake</field>
        <value name="VALUE">
          <block type="math_number" id="md_init_num">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="md_stake_set">
            <field name="VAR" id="md_stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="md_init_get">
                <field name="VAR" id="md_init_stake">initial_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="md_prediction_set">
                <field name="VAR" id="md_prediction">prediction</field>
                <value name="VALUE">
                  <!-- Change this digit (0-9) to pick which digit to avoid -->
                  <block type="math_number" id="md_prediction_num">
                    <field name="NUM">5</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="md_profit_set">
                    <field name="VAR" id="md_profit_target">profit_target</field>
                    <value name="VALUE">
                      <block type="math_number" id="md_profit_num">
                        <field name="NUM">10</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="md_maxloss_set">
                        <field name="VAR" id="md_max_loss">max_loss_streak</field>
                        <value name="VALUE">
                          <block type="math_number" id="md_maxloss_num">
                            <field name="NUM">5</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="md_losscount_set">
                            <field name="VAR" id="md_loss_count">loss_count</field>
                            <value name="VALUE">
                              <block type="math_number" id="md_losscount_num">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="md_tradeopts">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="md_dur_shadow">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="md_amt_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="md_stake_get">
            <field name="VAR" id="md_stake">stake</field>
          </block>
        </value>
        <value name="PREDICTION">
          <shadow type="math_number_positive" id="md_pred_shadow" inline="true">
            <field name="NUM">5</field>
          </shadow>
          <block type="variables_get" id="md_prediction_get">
            <field name="VAR" id="md_prediction">prediction</field>
          </block>
        </value>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="md_before" deletable="false" x="600" y="0">
    <statement name="BEFOREPURCHASE_STACK">
      <!-- DIGITDIFF = win if last digit ≠ prediction
           Switch to DIGITMATCH = win if last digit = prediction -->
      <block type="purchase" id="md_purchase">
        <field name="PURCHASE_LIST">DIGITDIFF</field>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="md_after" x="600" y="280">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="md_result_check">
        <mutation else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="md_win_result">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="md_win_stake_reset">
            <field name="VAR" id="md_stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="md_win_init_get">
                <field name="VAR" id="md_init_stake">initial_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="md_win_losscount_reset">
                <field name="VAR" id="md_loss_count">loss_count</field>
                <value name="VALUE">
                  <block type="math_number" id="md_win_losscount_num">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="notify" id="md_win_notify">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <field name="NOTIFICATION_SOUND">earned-money</field>
                    <value name="MESSAGE">
                      <shadow type="text" id="md_win_msg_shadow">
                        <field name="TEXT">Win!</field>
                      </shadow>
                      <block type="text" id="md_win_msg">
                        <field name="TEXT">Differs Win!</field>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="md_profit_check">
                        <value name="IF0">
                          <block type="logic_compare" id="md_profit_compare">
                            <field name="OP">LT</field>
                            <value name="A">
                              <block type="total_profit" id="md_total_profit"></block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="md_profit_target_get">
                                <field name="VAR" id="md_profit_target">profit_target</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="trade_again" id="md_win_trade_again"></block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="math_change" id="md_loss_increment">
            <field name="VAR" id="md_loss_count">loss_count</field>
            <value name="DELTA">
              <shadow type="math_number" id="md_loss_delta">
                <field name="NUM">1</field>
              </shadow>
            </value>
            <next>
              <block type="variables_set" id="md_loss_stake_multiply">
                <field name="VAR" id="md_stake">stake</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="md_stake_multiply">
                    <field name="OP">MULTIPLY</field>
                    <value name="A">
                      <shadow type="math_number" id="md_mult_a">
                        <field name="NUM">1</field>
                      </shadow>
                      <block type="variables_get" id="md_loss_stake_get">
                        <field name="VAR" id="md_stake">stake</field>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="md_mult_b">
                        <field name="NUM">2.5</field>
                      </shadow>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="notify" id="md_loss_notify">
                    <field name="NOTIFICATION_TYPE">error</field>
                    <field name="NOTIFICATION_SOUND">silent</field>
                    <value name="MESSAGE">
                      <shadow type="text" id="md_loss_msg_shadow">
                        <field name="TEXT">Loss.</field>
                      </shadow>
                      <block type="text" id="md_loss_msg">
                        <field name="TEXT">Loss. Recovering.</field>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="md_loss_streak_check">
                        <value name="IF0">
                          <block type="logic_compare" id="md_streak_compare">
                            <field name="OP">LT</field>
                            <value name="A">
                              <block type="variables_get" id="md_loss_count_get">
                                <field name="VAR" id="md_loss_count">loss_count</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="md_max_loss_get">
                                <field name="VAR" id="md_max_loss">max_loss_streak</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="trade_again" id="md_loss_trade_again"></block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
