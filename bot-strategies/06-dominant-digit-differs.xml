<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="dd_stake">stake</variable>
    <variable id="dd_init_stake">initial_stake</variable>
    <variable id="dd_profit_target">profit_target</variable>
    <variable id="dd_loss_count">loss_count</variable>
    <variable id="dd_max_loss">max_loss_streak</variable>
    <variable id="dd_hot_digit">hot_digit</variable>
    <variable id="dd_tick_count">tick_count</variable>
    <variable id="dd_sample_size">sample_size</variable>
    <variable id="dd_d0">d0</variable>
    <variable id="dd_d1">d1</variable>
    <variable id="dd_d2">d2</variable>
    <variable id="dd_d3">d3</variable>
    <variable id="dd_d4">d4</variable>
    <variable id="dd_d5">d5</variable>
    <variable id="dd_d6">d6</variable>
    <variable id="dd_d7">d7</variable>
    <variable id="dd_d8">d8</variable>
    <variable id="dd_d9">d9</variable>
  </variables>

  <!-- ═══════════════════════════════════════════════
       MKULIMA TRADER — Dominant Digit Differs Bot
       Strategy : Track last digit frequency over a
                  rolling sample; bet DIGITDIFF against
                  whichever digit appeared most (the
                  "dominant" digit is statistically
                  likely to revert to mean).
       Market   : Vol 50 (1s) — pipSize 4, predictable
       Entry    : After sample_size ticks collected
       Exit     : Stop at profit_target or max_loss
       ═══════════════════════════════════════════════ -->
  <block type="trade_definition" id="dd_trade_def" deletable="false" x="0" y="0">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="dd_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ50V</field>
        <next>
          <block type="trade_definition_tradetype" id="dd_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">matchesdiffers</field>
            <next>
              <block type="trade_definition_contracttype" id="dd_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">differs</field>
                <next>
                  <block type="trade_definition_candleinterval" id="dd_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="dd_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="dd_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <!-- Initialise all counters and settings -->
      <block type="variables_set" id="dd_init_stake_set">
        <field name="VAR" id="dd_init_stake">initial_stake</field>
        <value name="VALUE">
          <block type="math_number" id="dd_init_num">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="dd_stake_set">
            <field name="VAR" id="dd_stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="dd_init_get">
                <field name="VAR" id="dd_init_stake">initial_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="dd_profit_set">
                <field name="VAR" id="dd_profit_target">profit_target</field>
                <value name="VALUE">
                  <block type="math_number" id="dd_profit_num">
                    <field name="NUM">15</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="dd_maxloss_set">
                    <field name="VAR" id="dd_max_loss">max_loss_streak</field>
                    <value name="VALUE">
                      <block type="math_number" id="dd_maxloss_num">
                        <field name="NUM">5</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="dd_sample_set">
                        <field name="VAR" id="dd_sample_size">sample_size</field>
                        <value name="VALUE">
                          <!-- Collect this many ticks before first trade -->
                          <block type="math_number" id="dd_sample_num">
                            <field name="NUM">20</field>
                          </block>
                        </value>
                        <next>
                          <block type="variables_set" id="dd_tick_set">
                            <field name="VAR" id="dd_tick_count">tick_count</field>
                            <value name="VALUE">
                              <block type="math_number" id="dd_tick_num">
                                <field name="NUM">0</field>
                              </block>
                            </value>
                            <next>
                              <block type="variables_set" id="dd_hot_set">
                                <field name="VAR" id="dd_hot_digit">hot_digit</field>
                                <value name="VALUE">
                                  <block type="math_number" id="dd_hot_num">
                                    <field name="NUM">0</field>
                                  </block>
                                </value>
                                <next>
                                  <block type="variables_set" id="dd_d0_set">
                                    <field name="VAR" id="dd_d0">d0</field>
                                    <value name="VALUE"><block type="math_number" id="dd_d0_num"><field name="NUM">0</field></block></value>
                                    <next><block type="variables_set" id="dd_d1_set">
                                      <field name="VAR" id="dd_d1">d1</field>
                                      <value name="VALUE"><block type="math_number" id="dd_d1_num"><field name="NUM">0</field></block></value>
                                      <next><block type="variables_set" id="dd_d2_set">
                                        <field name="VAR" id="dd_d2">d2</field>
                                        <value name="VALUE"><block type="math_number" id="dd_d2_num"><field name="NUM">0</field></block></value>
                                        <next><block type="variables_set" id="dd_d3_set">
                                          <field name="VAR" id="dd_d3">d3</field>
                                          <value name="VALUE"><block type="math_number" id="dd_d3_num"><field name="NUM">0</field></block></value>
                                          <next><block type="variables_set" id="dd_d4_set">
                                            <field name="VAR" id="dd_d4">d4</field>
                                            <value name="VALUE"><block type="math_number" id="dd_d4_num"><field name="NUM">0</field></block></value>
                                            <next><block type="variables_set" id="dd_d5_set">
                                              <field name="VAR" id="dd_d5">d5</field>
                                              <value name="VALUE"><block type="math_number" id="dd_d5_num"><field name="NUM">0</field></block></value>
                                              <next><block type="variables_set" id="dd_d6_set">
                                                <field name="VAR" id="dd_d6">d6</field>
                                                <value name="VALUE"><block type="math_number" id="dd_d6_num"><field name="NUM">0</field></block></value>
                                                <next><block type="variables_set" id="dd_d7_set">
                                                  <field name="VAR" id="dd_d7">d7</field>
                                                  <value name="VALUE"><block type="math_number" id="dd_d7_num"><field name="NUM">0</field></block></value>
                                                  <next><block type="variables_set" id="dd_d8_set">
                                                    <field name="VAR" id="dd_d8">d8</field>
                                                    <value name="VALUE"><block type="math_number" id="dd_d8_num"><field name="NUM">0</field></block></value>
                                                    <next><block type="variables_set" id="dd_d9_set">
                                                      <field name="VAR" id="dd_d9">d9</field>
                                                      <value name="VALUE"><block type="math_number" id="dd_d9_num"><field name="NUM">0</field></block></value>
                                                    </block></next>
                                                  </block></next>
                                                </block></next>
                                              </block></next>
                                            </block></next>
                                          </block></next>
                                        </block></next>
                                      </block></next>
                                    </block></next>
                                  </block>
                                </next>
                              </block>
                            </next>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <!-- Increment tick count and track last digit -->
      <block type="math_change" id="dd_tick_inc">
        <field name="VAR" id="dd_tick_count">tick_count</field>
        <value name="DELTA">
          <shadow type="math_number" id="dd_tick_delta">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <next>
          <!-- Only trade after sample collected -->
          <block type="controls_if" id="dd_sample_gate">
            <value name="IF0">
              <block type="logic_compare" id="dd_sample_compare">
                <field name="OP">GTE</field>
                <value name="A">
                  <block type="variables_get" id="dd_tick_count_get">
                    <field name="VAR" id="dd_tick_count">tick_count</field>
                  </block>
                </value>
                <value name="B">
                  <block type="variables_get" id="dd_sample_size_get">
                    <field name="VAR" id="dd_sample_size">sample_size</field>
                  </block>
                </value>
              </block>
            </value>
            <statement name="DO0">
              <block type="trade_definition_tradeoptions" id="dd_tradeopts">
                <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="true"></mutation>
                <field name="DURATIONTYPE_LIST">t</field>
                <value name="DURATION">
                  <shadow type="math_number_positive" id="dd_dur_shadow">
                    <field name="NUM">1</field>
                  </shadow>
                </value>
                <value name="AMOUNT">
                  <shadow type="math_number_positive" id="dd_amt_shadow">
                    <field name="NUM">1</field>
                  </shadow>
                  <block type="variables_get" id="dd_stake_get">
                    <field name="VAR" id="dd_stake">stake</field>
                  </block>
                </value>
                <value name="PREDICTION">
                  <shadow type="math_number_positive" id="dd_pred_shadow" inline="true">
                    <field name="NUM">0</field>
                  </shadow>
                  <!-- hot_digit is updated in after_purchase -->
                  <block type="variables_get" id="dd_hot_digit_get">
                    <field name="VAR" id="dd_hot_digit">hot_digit</field>
                  </block>
                </value>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="dd_before" deletable="false" x="600" y="0">
    <statement name="BEFOREPURCHASE_STACK">
      <!-- Bet DIFFERS against hot_digit -->
      <block type="purchase" id="dd_purchase">
        <field name="PURCHASE_LIST">DIGITDIFF</field>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="dd_after" x="600" y="280">
    <statement name="AFTERPURCHASE_STACK">
      <!-- Reset tick counter to refresh sample next round -->
      <block type="variables_set" id="dd_tick_reset">
        <field name="VAR" id="dd_tick_count">tick_count</field>
        <value name="VALUE">
          <block type="math_number" id="dd_tick_reset_num">
            <field name="NUM">0</field>
          </block>
        </value>
        <next>
          <block type="controls_if" id="dd_result_check">
            <mutation else="1"></mutation>
            <value name="IF0">
              <block type="contract_check_result" id="dd_win_result">
                <field name="CHECK_RESULT">win</field>
              </block>
            </value>
            <statement name="DO0">
              <block type="variables_set" id="dd_win_stake_reset">
                <field name="VAR" id="dd_stake">stake</field>
                <value name="VALUE">
                  <block type="variables_get" id="dd_win_init_get">
                    <field name="VAR" id="dd_init_stake">initial_stake</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="dd_win_losscount_reset">
                    <field name="VAR" id="dd_loss_count">loss_count</field>
                    <value name="VALUE">
                      <block type="math_number" id="dd_win_losscount_num">
                        <field name="NUM">0</field>
                      </block>
                    </value>
                    <next>
                      <block type="notify" id="dd_win_notify">
                        <field name="NOTIFICATION_TYPE">success</field>
                        <field name="NOTIFICATION_SOUND">earned-money</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="dd_win_msg_shadow">
                            <field name="TEXT">Win!</field>
                          </shadow>
                          <block type="text" id="dd_win_msg">
                            <field name="TEXT">Dominant Digit Differs — Win!</field>
                          </block>
                        </value>
                        <next>
                          <block type="controls_if" id="dd_profit_check">
                            <value name="IF0">
                              <block type="logic_compare" id="dd_profit_compare">
                                <field name="OP">LT</field>
                                <value name="A">
                                  <block type="total_profit" id="dd_total_profit"></block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="dd_profit_target_get">
                                    <field name="VAR" id="dd_profit_target">profit_target</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="trade_again" id="dd_win_trade_again"></block>
                            </statement>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
            <statement name="ELSE">
              <block type="math_change" id="dd_loss_increment">
                <field name="VAR" id="dd_loss_count">loss_count</field>
                <value name="DELTA">
                  <shadow type="math_number" id="dd_loss_delta">
                    <field name="NUM">1</field>
                  </shadow>
                </value>
                <next>
                  <block type="variables_set" id="dd_loss_stake_multiply">
                    <field name="VAR" id="dd_stake">stake</field>
                    <value name="VALUE">
                      <block type="math_arithmetic" id="dd_stake_multiply">
                        <field name="OP">MULTIPLY</field>
                        <value name="A">
                          <shadow type="math_number" id="dd_mult_a">
                            <field name="NUM">1</field>
                          </shadow>
                          <block type="variables_get" id="dd_loss_stake_get">
                            <field name="VAR" id="dd_stake">stake</field>
                          </block>
                        </value>
                        <value name="B">
                          <shadow type="math_number" id="dd_mult_b">
                            <field name="NUM">2.5</field>
                          </shadow>
                        </value>
                      </block>
                    </value>
                    <next>
                      <block type="notify" id="dd_loss_notify">
                        <field name="NOTIFICATION_TYPE">error</field>
                        <field name="NOTIFICATION_SOUND">silent</field>
                        <value name="MESSAGE">
                          <shadow type="text" id="dd_loss_msg_shadow">
                            <field name="TEXT">Loss. Recovering.</field>
                          </shadow>
                          <block type="text" id="dd_loss_msg">
                            <field name="TEXT">Loss. Increasing stake.</field>
                          </block>
                        </value>
                        <next>
                          <block type="controls_if" id="dd_loss_streak_check">
                            <value name="IF0">
                              <block type="logic_compare" id="dd_streak_compare">
                                <field name="OP">LT</field>
                                <value name="A">
                                  <block type="variables_get" id="dd_loss_count_get">
                                    <field name="VAR" id="dd_loss_count">loss_count</field>
                                  </block>
                                </value>
                                <value name="B">
                                  <block type="variables_get" id="dd_max_loss_get">
                                    <field name="VAR" id="dd_max_loss">max_loss_streak</field>
                                  </block>
                                </value>
                              </block>
                            </value>
                            <statement name="DO0">
                              <block type="trade_again" id="dd_loss_trade_again"></block>
                            </statement>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </statement>
          </block>
        </next>
      </block>
    </statement>
  </block>
</xml>
