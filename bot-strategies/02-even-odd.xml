<xml xmlns="https://developers.google.com/blockly/xml" is_dbot="true" collection="false">
  <variables>
    <variable id="eo_stake">stake</variable>
    <variable id="eo_init_stake">initial_stake</variable>
    <variable id="eo_profit_target">profit_target</variable>
    <variable id="eo_loss_count">loss_count</variable>
    <variable id="eo_max_loss">max_loss_streak</variable>
  </variables>

  <!-- ═══════════════════════════════════════════════
       MKULIMA TRADER — Even/Odd Bot
       Strategy : Bet DIGITEVEN on Volatility 75 (1s)
       Entry    : Fixed stake, martingale x2.1 on loss
       Exit     : Stop at profit_target or max_loss_streak
       ═══════════════════════════════════════════════ -->
  <block type="trade_definition" id="eo_trade_def" deletable="false" x="0" y="0">
    <statement name="TRADE_OPTIONS">
      <block type="trade_definition_market" id="eo_market" deletable="false" movable="false">
        <field name="MARKET_LIST">synthetic_index</field>
        <field name="SUBMARKET_LIST">random_index</field>
        <field name="SYMBOL_LIST">1HZ75V</field>
        <next>
          <block type="trade_definition_tradetype" id="eo_tradetype" deletable="false" movable="false">
            <field name="TRADETYPECAT_LIST">digits</field>
            <field name="TRADETYPE_LIST">evenodd</field>
            <next>
              <block type="trade_definition_contracttype" id="eo_contracttype" deletable="false" movable="false">
                <field name="TYPE_LIST">even</field>
                <next>
                  <block type="trade_definition_candleinterval" id="eo_candle" deletable="false" movable="false">
                    <field name="CANDLEINTERVAL_LIST">60</field>
                    <next>
                      <block type="trade_definition_restartbuysell" id="eo_restart" deletable="false" movable="false">
                        <field name="TIME_MACHINE_ENABLED">FALSE</field>
                        <next>
                          <block type="trade_definition_restartonerror" id="eo_restarterr" deletable="false" movable="false">
                            <field name="RESTARTONERROR">TRUE</field>
                          </block>
                        </next>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="INITIALIZATION">
      <block type="variables_set" id="eo_init_stake_set">
        <field name="VAR" id="eo_init_stake">initial_stake</field>
        <value name="VALUE">
          <block type="math_number" id="eo_init_num">
            <field name="NUM">1</field>
          </block>
        </value>
        <next>
          <block type="variables_set" id="eo_stake_set">
            <field name="VAR" id="eo_stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="eo_init_get">
                <field name="VAR" id="eo_init_stake">initial_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="eo_profit_set">
                <field name="VAR" id="eo_profit_target">profit_target</field>
                <value name="VALUE">
                  <block type="math_number" id="eo_profit_num">
                    <field name="NUM">10</field>
                  </block>
                </value>
                <next>
                  <block type="variables_set" id="eo_maxloss_set">
                    <field name="VAR" id="eo_max_loss">max_loss_streak</field>
                    <value name="VALUE">
                      <block type="math_number" id="eo_maxloss_num">
                        <field name="NUM">7</field>
                      </block>
                    </value>
                    <next>
                      <block type="variables_set" id="eo_losscount_set">
                        <field name="VAR" id="eo_loss_count">loss_count</field>
                        <value name="VALUE">
                          <block type="math_number" id="eo_losscount_num">
                            <field name="NUM">0</field>
                          </block>
                        </value>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </next>
      </block>
    </statement>

    <statement name="SUBMARKET">
      <block type="trade_definition_tradeoptions" id="eo_tradeopts">
        <mutation xmlns="http://www.w3.org/1999/xhtml" has_first_barrier="false" has_second_barrier="false" has_prediction="false"></mutation>
        <field name="DURATIONTYPE_LIST">t</field>
        <value name="DURATION">
          <shadow type="math_number_positive" id="eo_dur_shadow">
            <field name="NUM">1</field>
          </shadow>
        </value>
        <value name="AMOUNT">
          <shadow type="math_number_positive" id="eo_amt_shadow">
            <field name="NUM">1</field>
          </shadow>
          <block type="variables_get" id="eo_stake_get">
            <field name="VAR" id="eo_stake">stake</field>
          </block>
        </value>
      </block>
    </statement>
  </block>

  <block type="before_purchase" id="eo_before" deletable="false" x="600" y="0">
    <statement name="BEFOREPURCHASE_STACK">
      <!-- Always bet EVEN — change to DIGITODD to flip strategy -->
      <block type="purchase" id="eo_purchase">
        <field name="PURCHASE_LIST">DIGITEVEN</field>
      </block>
    </statement>
  </block>

  <block type="after_purchase" id="eo_after" x="600" y="280">
    <statement name="AFTERPURCHASE_STACK">
      <block type="controls_if" id="eo_result_check">
        <mutation else="1"></mutation>
        <value name="IF0">
          <block type="contract_check_result" id="eo_win_result">
            <field name="CHECK_RESULT">win</field>
          </block>
        </value>
        <statement name="DO0">
          <block type="variables_set" id="eo_win_stake_reset">
            <field name="VAR" id="eo_stake">stake</field>
            <value name="VALUE">
              <block type="variables_get" id="eo_win_init_get">
                <field name="VAR" id="eo_init_stake">initial_stake</field>
              </block>
            </value>
            <next>
              <block type="variables_set" id="eo_win_losscount_reset">
                <field name="VAR" id="eo_loss_count">loss_count</field>
                <value name="VALUE">
                  <block type="math_number" id="eo_win_losscount_num">
                    <field name="NUM">0</field>
                  </block>
                </value>
                <next>
                  <block type="notify" id="eo_win_notify">
                    <field name="NOTIFICATION_TYPE">success</field>
                    <field name="NOTIFICATION_SOUND">earned-money</field>
                    <value name="MESSAGE">
                      <shadow type="text" id="eo_win_msg_shadow">
                        <field name="TEXT">Win!</field>
                      </shadow>
                      <block type="text" id="eo_win_msg">
                        <field name="TEXT">Even/Odd Win!</field>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="eo_profit_check">
                        <value name="IF0">
                          <block type="logic_compare" id="eo_profit_compare">
                            <field name="OP">LT</field>
                            <value name="A">
                              <block type="total_profit" id="eo_total_profit"></block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="eo_profit_target_get">
                                <field name="VAR" id="eo_profit_target">profit_target</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="trade_again" id="eo_win_trade_again"></block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
        <statement name="ELSE">
          <block type="math_change" id="eo_loss_increment">
            <field name="VAR" id="eo_loss_count">loss_count</field>
            <value name="DELTA">
              <shadow type="math_number" id="eo_loss_delta">
                <field name="NUM">1</field>
              </shadow>
            </value>
            <next>
              <block type="variables_set" id="eo_loss_stake_multiply">
                <field name="VAR" id="eo_stake">stake</field>
                <value name="VALUE">
                  <block type="math_arithmetic" id="eo_stake_multiply">
                    <field name="OP">MULTIPLY</field>
                    <value name="A">
                      <shadow type="math_number" id="eo_mult_a">
                        <field name="NUM">1</field>
                      </shadow>
                      <block type="variables_get" id="eo_loss_stake_get">
                        <field name="VAR" id="eo_stake">stake</field>
                      </block>
                    </value>
                    <value name="B">
                      <shadow type="math_number" id="eo_mult_b">
                        <field name="NUM">2.1</field>
                      </shadow>
                    </value>
                  </block>
                </value>
                <next>
                  <block type="notify" id="eo_loss_notify">
                    <field name="NOTIFICATION_TYPE">error</field>
                    <field name="NOTIFICATION_SOUND">silent</field>
                    <value name="MESSAGE">
                      <shadow type="text" id="eo_loss_msg_shadow">
                        <field name="TEXT">Loss.</field>
                      </shadow>
                      <block type="text" id="eo_loss_msg">
                        <field name="TEXT">Loss. Doubling up.</field>
                      </block>
                    </value>
                    <next>
                      <block type="controls_if" id="eo_loss_streak_check">
                        <value name="IF0">
                          <block type="logic_compare" id="eo_streak_compare">
                            <field name="OP">LT</field>
                            <value name="A">
                              <block type="variables_get" id="eo_loss_count_get">
                                <field name="VAR" id="eo_loss_count">loss_count</field>
                              </block>
                            </value>
                            <value name="B">
                              <block type="variables_get" id="eo_max_loss_get">
                                <field name="VAR" id="eo_max_loss">max_loss_streak</field>
                              </block>
                            </value>
                          </block>
                        </value>
                        <statement name="DO0">
                          <block type="trade_again" id="eo_loss_trade_again"></block>
                        </statement>
                      </block>
                    </next>
                  </block>
                </next>
              </block>
            </next>
          </block>
        </statement>
      </block>
    </statement>
  </block>
</xml>
