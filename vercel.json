{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "X-XSS-Protection",       "value": "1; mode=block" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/trader",   "destination": "/trader/index.html" },
    { "source": "/bot",      "destination": "/bot/index.html" },
    { "source": "/classic",  "destination": "/classic/index.html" },
    { "source": "/analyser", "destination": "/analyser/index.html" },
    { "source": "/callback", "destination": "/callback/index.html" }
  ]
}
